# Required — Jira Cloud base URL (no trailing slash)
JIRA_BASE_URL=https://yourorg.atlassian.net

# Required — Jira account email
JIRA_EMAIL=you@example.com

# Required — Jira API token (generate at https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_API_TOKEN=your_api_token_here

# Optional — HTTP listen port (default: 3000)
PORT=3000
